# Environment Variables

# Relayer private key (for signing bridge transactions)
RELAYER_PRIVATE_KEY=

# RPC endpoints
ETHEREUM_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
BASE_SEPOLIA_RPC=https://sepolia.base.org
RITUAL_RPC=https://rpc.ritualfoundation.org

# Contract deployer private key
DEPLOYER_PRIVATE_KEY=

# AI Provider (openai or openrouter)
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# WalletConnect Project ID (for frontend)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
